#!/usr/bin/env sh
if ! command -v pnpm >/dev/null 2>&1; then
  echo "⚠️  pnpm not found in PATH — skipping pre-commit hooks"
  echo "   Run 'pnpm run lint && pnpm run check:any-budget:t11' manually before pushing."
  exit 0
fi

pnpm exec lint-staged
node scripts/check-docs-sync.mjs
pnpm run check:any-budget:t11
